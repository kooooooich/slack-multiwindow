# Slack
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token   # ローカルはSocket Mode（これがあれば自動でSocket Modeで動作）

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# DB（ローカルはプロジェクトルートに保存、Railwayは Persistent Volume へ）
DATABASE_PATH=./app.db
# DATABASE_PATH=/data/app.db  # Railway用（Persistent Volume マウント先）

# アプリ
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# 簡易認証（設定しない場合は認証なし）
APP_PASSWORD=your-team-password
